# ----------------------------------------------------------------------------
# Sports Finder MVP — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ----------------------------------------------------------------------------

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
# Found in: Supabase Dashboard > Project Settings > Data API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to the browser; protected by RLS)
# Found in: Supabase Dashboard > Project Settings > API Keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (SERVER ONLY — bypasses RLS, never expose to client)
# Used by seed scripts / privileged server actions. Leave blank if unused.
# Found in: Supabase Dashboard > Project Settings > API Keys > service_role
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the app (used for auth redirects). Local dev default below.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
